<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/colorBackground">

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido a ViajesExpress"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tvDescripcionInicio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Desde acá podés ver viajes disponibles, reservar asientos y consultar tus reservas."
        android:textSize="16sp"
        android:textColor="@color/colorTextPrimary"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnVerViajes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver Viajes"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnMisReservas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mis Reservas" />

</LinearLayout>